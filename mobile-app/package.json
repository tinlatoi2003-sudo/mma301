{
  "name": "room-management-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start --localhost",
    "start": "expo start --localhost",
    "android": "set \"ANDROID_HOME=%LOCALAPPDATA%\\Android\\Sdk\" && set \"PATH=%LOCALAPPDATA%\\Android\\Sdk\\platform-tools;%LOCALAPPDATA%\\Android\\Sdk\\emulator;%PATH%\" && expo start --android --localhost --port 8082 --clear",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:apk": "eas build -p android --profile preview",
    "build:aab": "eas build -p android --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "expo": "~51.0.8",
    "expo-constants": "~16.0.2",
    "expo-status-bar": "~1.12.1",
    "expo-vector-icons": "^10.0.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1"
  }
}
